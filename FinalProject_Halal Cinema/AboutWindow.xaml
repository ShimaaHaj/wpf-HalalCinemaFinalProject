<Window x:Class="FinalProject_Halal_Cinema.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalProject_Halal_Cinema"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="AboutWindow" Height="700" Width="650">





    <Grid Background="#f4f6fd">

        <Border Margin="25"
                CornerRadius="10"
                Background="#fafafc"
                BorderBrush="#ebedf9"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->

                <Border Grid.Row="0"
                        Background="#043b98">

                    <TextBlock Text="حول النظام"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- Content -->

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="🎬"
                               FontSize="60"
                               Margin="0,20,0,0"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="Halal Cinema"
                               FontSize="34"
                               FontWeight="ExtraBold"
                               Foreground="#043b98"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0" />

                    <TextBlock Text="نظام حجز سينمائي تعليمي"
                               FontSize="15"
                               Foreground="#7b8297"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0" />

                    <Border Background="#E9EEFB"
                            Margin="80,30,80,0"
                            CornerRadius="8">

                        <TextBlock Text="يتيح النظام للمستخدم استعراض الأفلام المتاحة واختيار مواعيد العرض والتنقل بين الأفلام وحجز المقاعد بطريقة سهلة ومنظمة."
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="20"
                                   FontSize="14"
                                   Foreground="#3b4257" />
                    </Border>

                    <TextBlock Text="wpf | C#"
                               FontSize="14"
                               Foreground="#7b8297"
                               HorizontalAlignment="Center"
                               Margin="0,25,0,0" />

                    <TextBlock Text="تم تطوير المشروع بواسطة"
                               FontSize="13"
                               Foreground="#7b8297"
                               HorizontalAlignment="Center"
                               Margin="0,25,0,0" />

                    <TextBlock Text="شيماء حاج"
                               FontSize="22"
                               FontWeight="ExtraBold"
                               Foreground="#043b98"
                               HorizontalAlignment="Center" />

                </StackPanel>

                <!-- Footer -->

                <Border Grid.Row="2"
                        Background="#eaf0fb">

                    <Button x:Name="btnClose"
                            Content="إغلاق"
                            Width="140"
                            Height="35"
                            Background="#043b98"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Border>

            </Grid>

        </Border>

    </Grid>
</Window>
