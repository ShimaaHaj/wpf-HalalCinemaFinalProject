<Window x:Class="FinalProject_Halal_Cinema.SelectDateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalProject_Halal_Cinema"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="التواريخ" Height="750" Width="900">










    <Grid Background="#f4f6fd">


        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="9*"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#043b98">
            <TextBlock Text="اختر اليوم 🍿" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="60,0,0,0" FontSize="20" Foreground="#dee4f2"></TextBlock>
        </Border>

        <Border Grid.Row="1" CornerRadius="7" Margin="30,30,30,30" BorderThickness="1" BorderBrush="#ebedf9" Background="#fafafc">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="9*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>


                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"></RowDefinition>
                        <RowDefinition Height="2*"></RowDefinition>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="1" Margin="60,20,60,20" Background="#E9EEFB" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="5*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Image Source="img/ci2.png" Margin="30"></Image>
                            <Border Grid.Column="1" Background="#90a6df" Width="1" Margin="0,30,0,30"></Border>
                            <StackPanel Grid.Column="2" Margin="0,30,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,30,0">
                                    <TextBlock Text="معلومات" FontSize="20" FontWeight="ExtraBold" Foreground="#385fc3"></TextBlock>
                                    <Border CornerRadius="12" BorderBrush="#7c97d6" BorderThickness="1" Background="#0235a1" Margin="10,0,0,0">
                                        <TextBlock Text="  i  " FontSize="25" Foreground="White"></TextBlock>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="يتم عرض الأفلام المتاحة فقط في أيام معينة..." FlowDirection="RightToLeft" Margin="0,0,80,0" Foreground="#696c82" FontWeight="Thin" FontSize="15"></TextBlock>
                                <TextBlock Text="اختر اليوم المناسب لعرض الافلام الشاغرة لذاك" FlowDirection="RightToLeft" Margin="0,0,80,0" Foreground="#696c82" FontWeight="Thin" FontSize="15"></TextBlock>
                                <TextBlock Text="اليوم وتصفح الاوقات المناسبة ايضا." FlowDirection="RightToLeft" Margin="0,0,80,0" Foreground="#696c82" FontWeight="Thin" FontSize="15"></TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"></ColumnDefinition>
                            <ColumnDefinition Width="2*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="1" Margin="60,20,60,0" Background="#E9EEFB" CornerRadius="10">
                            <StackPanel Margin="0,20,0,0">
                                <Image Source="img/ci3.png"></Image>
                                <TextBlock Text="Halal Cinema" Foreground="#6177c7" FontWeight="ExtraBold" FontSize="24" HorizontalAlignment="Center" Margin="0,10,0,0"></TextBlock>
                                <TextBlock Text="تاريخ الحجز يبدا من تاريح اليوم" Foreground="#8c929f" FontWeight="ExtraBold" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"></TextBlock>
                                <TextBlock Text="اختر تاريخا من الايام الخمس الموالية" Foreground="#8c929f" FontWeight="ExtraBold" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,0"></TextBlock>
                            </StackPanel>
                        </Border>
                        <Calendar x:Name="myCalendar" Grid.Column="0" Margin="140,30,0,0"
                                  SelectedDatesChanged="myCalendar_SelectedDatesChanged">
                            <Calendar.LayoutTransform>
                                <ScaleTransform ScaleX="1.9" ScaleY="1.7" ></ScaleTransform>
                            </Calendar.LayoutTransform>
                        </Calendar>
                    </Grid>
                </Grid>


                <Border Grid.Row="1" Background="#eaf0fb" CornerRadius="0,0,0,0">
                    <Button Name="goHomePage" Content=" ↩ العودة للرئيسية" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" FontSize="20" FontWeight="ExtraBold" Foreground="#252c48" BorderThickness="0" Background="#eaf0fb"
                            Click="goHomePage_Click"
                            MouseEnter="goHomePage_MouseEnter"
                            MouseLeave="goHomePage_MouseLeave"></Button>
                </Border>
            </Grid>
        </Border>



    </Grid>
</Window>
