<Window x:Class="FinalProject_Halal_Cinema.MoviesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalProject_Halal_Cinema"
        mc:Ignorable="d"
        Title="المعرض" Height="750" Width="900">










    <Grid Background="#f4f6fd">


        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="9*"></RowDefinition>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#043b98">
            <TextBlock Text="تصفح المعرض 🍿" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="60,0,0,0" FontSize="20" Foreground="#dee4f2"></TextBlock>
        </Border>

        <Border Grid.Row="1" CornerRadius="7" Margin="30,30,30,30" BorderThickness="1" BorderBrush="#ebedf9" Background="#fafafc">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="9*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>


                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="2*"></ColumnDefinition>
                        <ColumnDefinition Width="3*"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="btnPrevious" Content=" ❰ " FontSize="40" Foreground="#435e9f"
                                Click="btnPrevious_Click"></Button>
                        <TextBlock Text="الســــابق" HorizontalAlignment="Center" FontWeight="Thin" FontSize="17" Margin="0,5,0,0"></TextBlock>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="0,70,20,0" CornerRadius="7" BorderThickness="2" BorderBrush="Black">
                            <Image x:Name="imgMovie" Source="img/ci1.png" Stretch="Fill"></Image>
                        </Border>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,20,0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border x:Name="dot1" BorderThickness="1" BorderBrush="Black" CornerRadius="10" Height="15" Width="15" Margin="5,0,0,40" Background="#023896"></Border>
                            <Border x:Name="dot2" BorderThickness="1" BorderBrush="Black" CornerRadius="10" Height="15" Width="15" Margin="5,0,0,40"></Border>
                            <Border x:Name="dot3" BorderThickness="1" BorderBrush="Black" CornerRadius="10" Height="15" Width="15" Margin="5,0,0,40"></Border>
                            <Border x:Name="dot4" BorderThickness="1" BorderBrush="Black" CornerRadius="10" Height="15" Width="15" Margin="5,0,0,40"></Border>
                            <Border x:Name="dot5" BorderThickness="1" BorderBrush="Black" CornerRadius="10" Height="15" Width="15" Margin="5,0,0,40"></Border>
                            <Border x:Name="dot6" BorderThickness="1" BorderBrush="Black" CornerRadius="10" Height="15" Width="15" Margin="5,0,0,40"></Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="2" Margin="0,30,0,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"></RowDefinition>
                            <RowDefinition Height="2*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="*"></RowDefinition>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="50,0,0,0">
                            <Border Background="#dae8f4" CornerRadius="3" HorizontalAlignment="Left" Margin="0,20,0,0">
                                <TextBlock x:Name="txtCategory" Text=" خيال علمي " Foreground="#4d6eb4" FontSize="11" FontWeight="ExtraBold"></TextBlock>
                            </Border>
                            <TextBlock x:Name="txtMovieName" Text="MoviesName" Foreground="#041337" FontSize="40" FontWeight="ExtraBold"></TextBlock>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="★" FontSize="20" Foreground="#4d6eb4" Margin="0,0,0,0"></TextBlock>
                                <TextBlock x:Name="txtRating" Text="8.6" FontSize="15" Foreground="#39395a" Margin="5,5,0,0"></TextBlock>
                                <TextBlock Text="/10" FontSize="15" Foreground="#39395a" Margin="0,5,0,0"></TextBlock>
                                <TextBlock Text="•" FontSize="15" Foreground="#4b5871" Margin="7,5,0,0"></TextBlock>
                                <TextBlock x:Name="txtYear" Text="2014" FontSize="15" Foreground="#767f95" Margin="7,5,0,0"></TextBlock>
                            </StackPanel>

                            <Border Background="#dae5f7" Margin="0,30,40,0" Height="1"></Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <TextBlock x:Name="txtDescription" Foreground="#8089a2" FontSize="14" Margin="50,30,60,0" Text="في مستقبل يواجه فيه البشر خطر الانقراض تنطلق رحلة عبر الفضاء للبحث عن موطن جديد يمكن أن يكون أمل البشرية." TextWrapping="Wrap" FlowDirection="RightToLeft" TextAlignment="Justify"></TextBlock>  
                            <Border Background="#dae5f7" Margin="50,40,40,0" Height="1"></Border>
                        </StackPanel>


                        <Grid Grid.Row="2" Margin="50,0,40,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"></RowDefinition>
                                <RowDefinition Height="2*"></RowDefinition>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,0" Orientation="Horizontal">
                                <TextBlock Text="🕘" Margin="10,0,0,3" FontSize="16" Foreground="#6480bd"></TextBlock>
                                <TextBlock Text="مواعيد العرض" Margin="10,0,0,0" FontSize="14" FontWeight="ExtraBold" Foreground="#071234"></TextBlock>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Margin="5" Background="#6480bd">
                                    <StackPanel>
                                        <TextBlock Text="11:00" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"></TextBlock>
                                        <TextBlock Text="صــــبحـاً" FontSize="11" FontWeight="Light" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Margin="5">
                                    <StackPanel>
                                        <TextBlock Text="20:30" VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
                                        <TextBlock Text="مــــسـاًء" FontSize="11" FontWeight="Light" Foreground="#76819d" VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Margin="5">
                                    <StackPanel>
                                        <TextBlock Text="10:00" VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
                                        <TextBlock Text="مــــسـاًء" FontSize="11" FontWeight="Light" Foreground="#76819d" VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>

                        <Button x:Name="btnBook" Grid.Row="3" Margin="50,10,40,10" Background="#063ea3" Content="احجز الان" Foreground="White"
                                Click="btnBook_Click"></Button>
                    </Grid>
                    
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="btnNext" Content=" ❱ " FontSize="40" Foreground="#435e9f"
                                Click="btnNext_Click"></Button>
                        <TextBlock Text="التــــالي" HorizontalAlignment="Center" FontWeight="Thin" FontSize="17" Margin="0,5,0,0"></TextBlock>
                    </StackPanel>
                </Grid>
                

                <Border Grid.Row="1" Background="#eaf0fb" CornerRadius="0,0,0,0">
                    <Button Name="goDatePage" Content=" ↩ العودة للتواريخ" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" FontSize="20" FontWeight="ExtraBold" Foreground="#252c48" BorderThickness="0" Background="#eaf0fb"
                            Click="goDatePage_Click"
                            MouseEnter="goDatePage_MouseEnter"
                            MouseLeave="goDatePage_MouseLeave"></Button>
                </Border>
            </Grid>
        </Border>



    </Grid>
</Window>
